# ===========================================
# NatID CRM - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# --- Base44 Platform ---
VITE_BASE44_APP_ID=your_app_id_here
VITE_BASE44_APP_BASE_URL=https://app.base44.com
VITE_BASE44_FUNCTIONS_VERSION=latest

# --- Twilio SMS (Backend) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+972xxxxxxxxx

# --- Google Maps (Backend - for distance calculation) ---
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# --- Bot Integration ---
BOT_WEBHOOK_SECRET=your_bot_webhook_secret_here
WEBHOOK_SECRET=your_webhook_secret_for_external_crm

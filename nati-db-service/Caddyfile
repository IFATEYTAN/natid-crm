# Replace `nati-db.example.co.il` with your real subdomain pointing at
# 209.38.178.128. Caddy will obtain a Let's Encrypt cert automatically.
#
# If you don't have a domain yet, comment this block and uncomment the
# IP-based block below to run with a self-signed cert (NOT recommended).

nati-db.example.co.il {
	encode zstd gzip
	reverse_proxy nati-db-service:8080 {
		header_up Host {host}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
		header_up X-Forwarded-Proto {scheme}
	}
}

# --- Self-signed fallback (no domain) ---
# :443 {
# 	tls internal
# 	reverse_proxy nati-db-service:8080
# }

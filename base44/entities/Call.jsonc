      "description": "\u05d8\u05d5\u05d5\u05d7 \u05e9\u05e2\u05d5\u05ea \u05dc\u05e9\u05d9\u05e8\u05d5\u05ea \u05e2\u05ea\u05d9\u05d3\u05d9"
    },
    "storage_days": {
      "type": "number",
      "description": "\u05de\u05e1\u05e4\u05e8 \u05d9\u05de\u05d9 \u05d0\u05d7\u05e1\u05e0\u05d4"
    },
    "closed_at": {
      "type": "string",
      "format": "date-time",
      "description": "\u05ea\u05d0\u05e8\u05d9\u05da \u05e1\u05d2\u05d9\u05e8\u05d4"
    },
    "closed_by": {
      "type": "string",
      "description": "\u05e9\u05dd \u05e1\u05d5\u05d2\u05e8 \u05d4\u05e7\u05e8\u05d9\u05d0\u05d4"
    },
    "customer_rating": {
      "type": "number",
      "description": "\u05d3\u05d9\u05e8\u05d5\u05d2 \u05e9\u05d1\u05d9\u05e2\u05d5\u05ea \u05e8\u05e6\u05d5\u05df"
    },
    "customer_feedback": {
      "type": "string",
      "description": "\u05de\u05e9\u05d5\u05d1 \u05d7\u05d5\u05e4\u05e9\u05d9"
    },
    "summary_draft": {
      "type": "string",
      "description": "\u05d8\u05d9\u05d5\u05d8\u05ea \u05e1\u05d9\u05db\u05d5\u05dd \u05e7\u05e8\u05d9\u05d0\u05d4"
    },
    "summary_final": {
      "type": "string",
      "description": "\u05e1\u05d9\u05db\u05d5\u05dd \u05e7\u05e8\u05d9\u05d0\u05d4 \u05e1\u05d5\u05e4\u05d9"
    },
    "questionnaire_answers": {
      "type": "object",
      "description": "\u05ea\u05e9\u05d5\u05d1\u05d5\u05ea \u05e9\u05d0\u05dc\u05d5\u05df \u05d8\u05db\u05e0\u05d9 \u05de\u05d4\u05d1\u05d5\u05d8"
    },
    "day_of_week": {
      "type": "string",
      "description": "\u05d9\u05d5\u05dd \u05d1\u05e9\u05d1\u05d5\u05e2 \u05e9\u05dc \u05d4\u05e7\u05e8\u05d9\u05d0\u05d4"
    },
    "hour_of_day": {
      "type": "number",
      "description": "\u05e9\u05e2\u05d4 \u05d1\u05d9\u05d5\u05dd (0-23)"
    },
    "closing_status": {
      "type": "string",
      "enum": [
        "mobile_done",
        "mobile_failed_evac",
        "mobile_failed_send",
        "tow_done",
        "tow_failed_complex",
        "extraction_continue",
        "tow_to_storage"
      ],
      "description": "\u05e1\u05d8\u05d8\u05d5\u05e1 \u05e1\u05d2\u05d9\u05e8\u05d4 \u2014 \u05ea\u05d5\u05e6\u05d0\u05ea \u05d4\u05d8\u05d9\u05e4\u05d5\u05dc \u05d1\u05e2\u05ea \u05e1\u05d2\u05d9\u05e8\u05ea \u05d4\u05e7\u05e8\u05d9\u05d0\u05d4"
    },
    "parent_call_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05e7\u05e8\u05d9\u05d0\u05ea \u05d4\u05de\u05e7\u05d5\u05e8 (\u05d0\u05dd \u05e7\u05e8\u05d9\u05d0\u05d4 \u05d6\u05d5 \u05d4\u05d9\u05d0 \u05e7\u05e8\u05d9\u05d0\u05ea \u05d4\u05de\u05e9\u05da)"
    },
    "continuation_call_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05e7\u05e8\u05d9\u05d0\u05ea \u05d4\u05d4\u05de\u05e9\u05da \u05e9\u05e0\u05e4\u05ea\u05d7\u05d4 \u05de\u05e7\u05e8\u05d9\u05d0\u05d4 \u05d6\u05d5"
    },
    "case_reference_code": {
      "type": "string",
      "description": "\u05e7\u05d5\u05d3 \u05d0\u05d9\u05e8\u05d5\u05e2 \u05de\u05e9\u05d5\u05ea\u05e3 \u05d4\u05de\u05e7\u05e9\u05e8 \u05d1\u05d9\u05df \u05de\u05e7\u05d8\u05e2\u05d9 \u05d8\u05d9\u05e4\u05d5\u05dc (\u05e7\u05e8\u05d9\u05d0\u05ea \u05de\u05e7\u05d5\u05e8 + \u05d4\u05de\u05e9\u05da)"
    },
    "reactivated_at": {
      "type": "string",
      "format": "date-time",
      "description": "\u05de\u05ea\u05d9 \u05d4\u05d5\u05e4\u05e2\u05dc\u05d4 \u05de\u05d7\u05d3\u05e9 \u05e9\u05dc \u05e7\u05e8\u05d9\u05d0\u05d4 \u05e9\u05e0\u05d3\u05d7\u05ea\u05d4 \u2014 \u05de\u05d0\u05e4\u05e1 \u05d0\u05ea \u05d8\u05d9\u05d9\u05de\u05e8 \u05d4\u05d4\u05d2\u05e2\u05d4 \u05dc\u05dc\u05e7\u05d5\u05d7"
    }
  },
  "required": [
    "customer_name",

{
  "name": "Call",
  "type": "object",
  "properties": {
    "call_number": {
      "type": "string",
      "description": "\u05de\u05e1\u05e4\u05e8 \u05e7\u05e8\u05d9\u05d0\u05d4 \u05d9\u05d9\u05d7\u05d5\u05d3\u05d9"
    },
    "call_status": {
      "type": "string",
      "enum": [
        "waiting_treatment",
        "awaiting_assignment",
        "assigning",
        "vendor_enroute",
        "in_progress",
        "vendor_arrived",
        "cannot_complete",
        "future_service",
        "in_followup",
        "in_storage",
        "continued_treatment",
        "awaiting_payment",
        "completed",
        "cancelled"
      ],
      "default": "waiting_treatment",
      "description": "\u05e1\u05d8\u05d8\u05d5\u05e1 \u05e7\u05e8\u05d9\u05d0\u05d4"
    },
    "created_by_source": {
      "type": "string",
      "enum": [
        "bot",
        "operator",
        "customer_app",
        "vendor_interface"
      ],
      "description": "\u05de\u05e7\u05d5\u05e8 \u05d4\u05e7\u05e8\u05d9\u05d0\u05d4"
    },
    "call_priority": {
      "type": "string",
      "enum": [
        "normal",
        "urgent",
        "critical"
      ],
      "default": "normal",
      "description": "\u05e2\u05d3\u05d9\u05e4\u05d5\u05ea"
    },
    "is_vip": {
      "type": "boolean",
      "default": false,
      "description": "\u05dc\u05e7\u05d5\u05d7 VIP"
    },
    "service_category": {
      "type": "string",
      "enum": [
        "towing",
        "mobile_unit",
        "towing_storage",
        "towing_mobile",
        "storage_only",
        "other"
      ],
      "description": "\u05e1\u05d5\u05d2 \u05e9\u05d9\u05e8\u05d5\u05ea (\u05d2, \u05e0, \u05d0+\u05d2, \u05d2+\u05e0, \u05d0, \u05d0\u05d7\u05e8)"
    },
    "dispatch_type": {
      "type": "string",
      "enum": [
        "mobile_unit",
        "tow_truck",
        "tow_truck_storage"
      ],
      "description": "\u05e1\u05d5\u05d2 \u05e8\u05db\u05d1 \u05e9\u05d9\u05e8\u05d5\u05ea / \u05e9\u05d9\u05d2\u05d5\u05e8: \u05e0\u05d9\u05d9\u05d3\u05ea, \u05d2\u05e8\u05e8, \u05d2\u05e8\u05e8 \u05e2\u05dd \u05d0\u05d7\u05e1\u05e0\u05d4"
    },
    "provider_type": {
      "type": "string",
      "enum": [
        "fleet",
        "external"
      ],
      "description": "\u05e1\u05d5\u05d2 \u05e1\u05e4\u05e7: \u05e6\u05d9 \u05e4\u05e0\u05d9\u05de\u05d9 \u05d0\u05d5 \u05e1\u05e4\u05e7 \u05d7\u05d9\u05e6\u05d5\u05e0\u05d9"
    },
    "fleet_vehicle_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05db\u05dc\u05d9 \u05e8\u05db\u05d1 \u05e6\u05d9 (\u05d0\u05dd \u05e4\u05e0\u05d9\u05de\u05d9)"
    },
    "fleet_vehicle_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05db\u05dc\u05d9 \u05e8\u05db\u05d1 \u05e6\u05d9"
    },
    "customer_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05de\u05dc\u05d0"
    },
    "customer_phone": {
      "type": "string",
      "description": "\u05d8\u05dc\u05e4\u05d5\u05df \u05e8\u05d0\u05e9\u05d9"
    },
    "customer_phone_2": {
      "type": "string",
      "description": "\u05d8\u05dc\u05e4\u05d5\u05df \u05de\u05e9\u05e0\u05d9"
    },
    "customer_id_number": {
      "type": "string",
      "description": "\u05ea\u05e2\u05d5\u05d3\u05ea \u05d6\u05d4\u05d5\u05ea"
    },
    "customer_email": {
      "type": "string",
      "description": "\u05d0\u05d9\u05de\u05d9\u05d9\u05dc"
    },
    "customer_address": {
      "type": "string",
      "description": "\u05db\u05ea\u05d5\u05d1\u05ea \u05de\u05d2\u05d5\u05e8\u05d9\u05dd"
    },
    "insurance_company": {
      "type": "string",
      "description": "\u05d7\u05d1\u05e8\u05ea \u05d1\u05d9\u05d8\u05d5\u05d7"
    },
    "insurance_agent": {
      "type": "string",
      "description": "\u05e1\u05d5\u05db\u05df \u05d1\u05d9\u05d8\u05d5\u05d7"
    },
    "membership_package": {
      "type": "string",
      "description": "\u05e9\u05dd \u05d4\u05d7\u05d1\u05d9\u05dc\u05d4"
    },
    "membership_number": {
      "type": "string",
      "description": "\u05de\u05e1\u05e4\u05e8 \u05de\u05e0\u05d5\u05d9"
    },
    "coverage_details": {
      "type": "string",
      "description": "\u05e4\u05d9\u05e8\u05d5\u05d8 \u05db\u05d9\u05e1\u05d5\u05d9 \u05d1\u05d9\u05d8\u05d5\u05d7\u05d9"
    },
    "vehicle_plate": {
      "type": "string",
      "description": "\u05de\u05e1\u05e4\u05e8 \u05e8\u05db\u05d1"
    },
    "vehicle_model": {
      "type": "string",
      "description": "\u05d3\u05d2\u05dd \u05de\u05dc\u05d0 \u05db\u05d5\u05dc\u05dc \u05e9\u05e0\u05d4"
    },
    "vehicle_year": {
      "type": "number",
      "description": "\u05e9\u05e0\u05ea \u05d9\u05d9\u05e6\u05d5\u05e8"
    },
    "vehicle_type": {
      "type": "string",
      "enum": [
        "private",
        "commercial_light",
        "truck",
        "motorcycle"
      ],
      "description": "\u05e1\u05d5\u05d2 \u05e8\u05db\u05d1"
    },
    "fuel_type": {
      "type": "string",
      "enum": [
        "gasoline",
        "diesel",
        "hybrid",
        "electric"
      ],
      "description": "\u05e1\u05d5\u05d2 \u05d3\u05dc\u05e7"
    },
    "vehicle_code": {
      "type": "string",
      "description": "\u05e7\u05d5\u05d3\u05df \u05dc\u05e8\u05db\u05d1 (\u05db\u05df/\u05dc\u05d0)"
    },
    "issue_type": {
      "type": "string",
      "enum": [
        "mechanical",
        "stopped_driving",
        "flat_tire",
        "stuck_wheel",
        "accident",
        "no_fuel",
        "dead_battery",
        "locked_keys",
        "other"
      ],
      "description": "\u05e1\u05d5\u05d2 \u05ea\u05e7\u05dc\u05d4"
    },
    "issue_description": {
      "type": "string",
      "description": "\u05ea\u05d9\u05d0\u05d5\u05e8 \u05d7\u05d5\u05e4\u05e9\u05d9"
    },
    "issue_detail": {
      "type": "string",
      "description": "\u05ea\u05d9\u05d0\u05d5\u05e8 \u05ea\u05e7\u05dc\u05d4 \u05de\u05e4\u05d5\u05e8\u05d8 (\u05db\u05e4\u05d9 \u05e9\u05de\u05d5\u05e4\u05d9\u05e2 \u05d1\u05d3\u05d5\u05d7\u05d5\u05ea)"
    },
    "operation_instructions": {
      "type": "string",
      "description": "\u05d4\u05d5\u05e8\u05d0\u05d5\u05ea \u05ea\u05e4\u05e2\u05d5\u05dc \u05dc\u05e7\u05e8\u05d9\u05d0\u05d4"
    },
    "pickup_location_address": {
      "type": "string",
      "description": "\u05db\u05ea\u05d5\u05d1\u05ea \u05de\u05d3\u05d5\u05d9\u05e7\u05ea \u05e9\u05dc \u05d4\u05e8\u05db\u05d1"
    },
    "pickup_location_city": {
      "type": "string",
      "description": "\u05e2\u05d9\u05e8"
    },
    "pickup_location_area": {
      "type": "string",
      "enum": [
        "center",
        "sharon",
        "north",
        "south",
        "jerusalem",
        "lowlands",
        "north_haifa",
        "north_jezreel",
        "north_galilee_west",
        "north_galilee_upper",
        "north_golan",
        "territories",
        "all_country",
        "undefined"
      ],
      "description": "\u05d0\u05d6\u05d5\u05e8 \u05d2\u05e8\u05d9\u05e8\u05d4"
    },
    "pickup_location_lat": {
      "type": "number",
      "description": "\u05e7\u05d5 \u05e8\u05d5\u05d7\u05d1"
    },
    "pickup_location_lon": {
      "type": "number",
      "description": "\u05e7\u05d5 \u05d0\u05d5\u05e8\u05da"
    },
    "dropoff_location_address": {
      "type": "string",
      "description": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d9\u05e2\u05d3"
    },
    "dropoff_location_city": {
      "type": "string",
      "description": "\u05e2\u05d9\u05e8 \u05d9\u05e2\u05d3"
    },
    "dropoff_location_area": {
      "type": "string",
      "enum": [
        "center",
        "sharon",
        "north",
        "south",
        "jerusalem",
        "lowlands",
        "north_haifa",
        "north_jezreel",
        "north_galilee_west",
        "north_galilee_upper",

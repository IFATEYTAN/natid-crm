    "cost_to_vendor": {
      "type": "number",
      "description": "\u05e2\u05dc\u05d5\u05ea \u05dc\u05e1\u05e4\u05e7"
    },
    "total_cost": {
      "type": "number",
      "description": "\u05e2\u05dc\u05d5\u05ea \u05db\u05d5\u05dc\u05dc\u05ea \u05e9\u05dc \u05d4\u05e7\u05e8\u05d9\u05d0\u05d4"

        "all_country",
        "undefined"
      ],
      "description": "\u05d0\u05d6\u05d5\u05e8 \u05d9\u05e2\u05d3"
    },
    "dropoff_garage_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05de\u05d5\u05e1\u05da"
    },
    "dropoff_garage_phone": {
      "type": "string",
      "description": "\u05d8\u05dc\u05e4\u05d5\u05df \u05de\u05d5\u05e1\u05da"
    },
    "storage_location_address": {
      "type": "string",
      "description": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d0\u05d7\u05e1\u05e0\u05d4"
    },
    "storage_location_city": {
      "type": "string",
      "description": "\u05e2\u05d9\u05e8 \u05d0\u05d7\u05e1\u05e0\u05d4"
    },
    "storage_location_area": {
      "type": "string",
      "enum": [
        "center",
        "sharon",
        "north",
        "south",
        "jerusalem",
        "lowlands"
      ],
      "description": "\u05d0\u05d6\u05d5\u05e8 \u05d0\u05d7\u05e1\u05e0\u05d4"
    },
    "is_road_accessible": {
      "type": "boolean",
      "description": "\u05d4\u05d0\u05dd \u05d9\u05e9 \u05d2\u05d9\u05e9\u05d4 \u05dc\u05de\u05e9\u05d0\u05d9\u05ea \u05d2\u05e8\u05e8"
    },
    "is_underground_parking": {
      "type": "boolean",
      "description": "\u05d4\u05d0\u05dd \u05d7\u05e0\u05d9\u05d5\u05df \u05ea\u05ea \u05e7\u05e8\u05e7\u05e2\u05d9"
    },
    "is_gear_neutral": {
      "type": "boolean",
      "description": "\u05d4\u05d0\u05dd \u05d9\u05d3\u05d9\u05ea \u05d4\u05d4\u05d9\u05dc\u05d5\u05db\u05d9\u05dd \u05e2\u05dc N"
    },
    "is_steering_locked": {
      "type": "boolean",
      "description": "\u05d4\u05d0\u05dd \u05d4\u05d4\u05d2\u05d4 \u05e0\u05e2\u05d5\u05dc"
    },
    "is_handbrake_released": {
      "type": "boolean",
      "description": "\u05d4\u05d0\u05dd \u05e9\u05d5\u05d7\u05e8\u05e8 \u05d1\u05dc\u05dd \u05d9\u05d3"
    },
    "is_toll_road": {
      "type": "boolean",
      "description": "\u05d4\u05d0\u05dd \u05e2\u05dc \u05db\u05d1\u05d9\u05e9 \u05d0\u05d2\u05e8\u05d4"
    },
    "is_customer_with_vehicle": {
      "type": "boolean",
      "description": "\u05d4\u05d0\u05dd \u05d4\u05dc\u05e7\u05d5\u05d7 \u05dc\u05d9\u05d3 \u05d4\u05e8\u05db\u05d1"
    },
    "has_key": {
      "type": "boolean",
      "description": "\u05d4\u05d0\u05dd \u05d9\u05e9 \u05de\u05e4\u05ea\u05d7"
    },
    "key_location": {
      "type": "string",
      "description": "\u05de\u05d9\u05e7\u05d5\u05dd \u05de\u05e4\u05ea\u05d7"
    },
    "customer_response_code": {
      "type": "string",
      "description": "\u05de\u05e1\u05e4\u05e8 \u05e7\u05d5\u05d3 \u05dc\u05d6\u05d9\u05d4\u05d5\u05d9"
    },
    "early_notification_minutes": {
      "type": "number",
      "default": 30,
      "description": "\u05d4\u05d5\u05d3\u05e2\u05d4 \u05de\u05d5\u05e7\u05d3\u05de\u05ea - \u05d3\u05e7\u05d5\u05ea \u05dc\u05e4\u05e0\u05d9 \u05d4\u05d2\u05e2\u05d4"
    },
    "assigned_vendor_id": {
      "type": "string",
      "description": "\u05e1\u05e4\u05e7 \u05de\u05e9\u05d5\u05d1\u05e5"
    },
    "assigned_vendor_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05e1\u05e4\u05e7 \u05de\u05e9\u05d5\u05d1\u05e5"
    },
    "assigned_vendor_area": {
      "type": "string",
      "description": "\u05d0\u05d6\u05d5\u05e8 \u05e0\u05d5\u05ea\u05df \u05d4\u05e9\u05d9\u05e8\u05d5\u05ea"
    },
    "assigned_at": {
      "type": "string",
      "format": "date-time",
      "description": "\u05de\u05ea\u05d9 \u05e9\u05d5\u05d1\u05e5"
    },
    "vendor_arrival_time_estimated": {
      "type": "string",
      "format": "date-time",
      "description": "\u05d6\u05de\u05df \u05d4\u05d2\u05e2\u05d4 \u05de\u05e9\u05d5\u05e2\u05e8"
    },
    "vendor_arrival_time_actual": {
      "type": "string",
      "format": "date-time",
      "description": "\u05d6\u05de\u05df \u05d4\u05d2\u05e2\u05d4 \u05d1\u05e4\u05d5\u05e2\u05dc"
    },
    "service_end_time": {
      "type": "string",
      "format": "date-time",
      "description": "\u05e9\u05e2\u05ea \u05e1\u05d9\u05d5\u05dd \u05d8\u05d9\u05e4\u05d5\u05dc"
    },
    "estimated_distance_km": {
      "type": "number",
      "description": "\u05de\u05e8\u05d7\u05e7 \u05de\u05d5\u05e2\u05e8\u05da \u05d1\u05e7\u05d9\u05dc\u05d5\u05de\u05d8\u05e8\u05d9\u05dd"
    },
    "actual_distance_km": {
      "type": "number",
      "description": "\u05de\u05e8\u05d7\u05e7 \u05d1\u05e4\u05d5\u05e2\u05dc \u05d1\u05e7\u05d9\u05dc\u05d5\u05de\u05d8\u05e8\u05d9\u05dd"
    },
    "estimated_arrival_time": {
      "type": "string",
      "format": "date-time",
      "description": "\u05d6\u05de\u05df \u05d4\u05d2\u05e2\u05d4 \u05de\u05e9\u05d5\u05e2\u05e8 \u05de\u05d7\u05e9\u05d5\u05d1"
    },
    "vendor_notes": {
      "type": "string",
      "description": "\u05d4\u05e2\u05e8\u05d5\u05ea \u05de\u05d4\u05e1\u05e4\u05e7"
    },
    "operator_notes": {
      "type": "string",
      "description": "\u05d4\u05e2\u05e8\u05d5\u05ea \u05de\u05d5\u05e7\u05d3\u05df"
    },
    "agent_notes": {
      "type": "string",
      "description": "\u05d4\u05e2\u05e8\u05d5\u05ea \u05d8\u05db\u05e0\u05d0\u05d9 \u05e9\u05d8\u05d7"
    },
    "cannot_complete_reason": {
      "type": "string",
      "description": "\u05e1\u05d9\u05d1\u05ea \u05d0\u05d9-\u05d9\u05db\u05d5\u05dc\u05ea \u05dc\u05d8\u05e4\u05dc \u05d1\u05e7\u05e8\u05d9\u05d0\u05d4 (\u05d3\u05d9\u05d5\u05d5\u05d7 \u05e1\u05e4\u05e7/\u05d8\u05db\u05e0\u05d0\u05d9)"
    },
    "time_waiting": {
      "type": "number",
      "description": "\u05d6\u05de\u05df \u05d4\u05de\u05ea\u05e0\u05d4 \u05d1\u05d3\u05e7\u05d5\u05ea"
    },
    "time_to_vendor_assignment": {
      "type": "number",
      "description": "\u05d6\u05de\u05df \u05e2\u05d3 \u05e9\u05d9\u05d5\u05da \u05e1\u05e4\u05e7"
    },
    "time_to_completion": {
      "type": "number",
      "description": "\u05d6\u05de\u05df \u05db\u05d5\u05dc\u05dc \u05de\u05e4\u05ea\u05d9\u05d7\u05d4 \u05dc\u05e1\u05d2\u05d9\u05e8\u05d4"
    },
    "sla_target": {
      "type": "number",
      "default": 30,

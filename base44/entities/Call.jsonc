    "quality_controller_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05d1\u05e7\u05e8"
    },
    "returned_to_agent": {
      "type": "boolean",
      "description": "\u05d7\u05d6\u05e8 \u05dc\u05de\u05d5\u05e7\u05d3\u05df"

    },
    "sla_status": {
      "type": "string",
      "enum": [
        "on_track",
        "near_breach",
        "breached"
      ],
      "description": "\u05e1\u05d8\u05d8\u05d5\u05e1 SLA"
    },
    "payment_required": {
      "type": "boolean",
      "description": "\u05d4\u05d0\u05dd \u05dc\u05e7\u05d5\u05d7 \u05de\u05e9\u05dc\u05dd"

{
  "name": "Agent",
  "type": "object",
  "properties": {
    "mysql_user_id": {
      "type": "number",
      "description": "\u05de\u05d6\u05d4\u05d4 MySQL \u05de\u05d8\u05d1\u05dc\u05ea users"
    },
    "agent_num": {
      "type": "number",
      "description": "\u05de\u05e1\u05e4\u05e8 \u05e1\u05d5\u05db\u05df"
    },
    "full_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05de\u05dc\u05d0"
    },
    "first_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05e4\u05e8\u05d8\u05d9"
    },
    "last_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05de\u05e9\u05e4\u05d7\u05d4"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "deleted"
      ],
      "default": "active",
      "description": "\u05e1\u05d8\u05d8\u05d5\u05e1"
    },
    "role": {
      "type": "string",
      "enum": [
        "agent",
        "salesagent",
        "clerk"
      ],
      "description": "\u05ea\u05e4\u05e7\u05d9\u05d3 (\u05e1\u05d5\u05db\u05df/\u05e1\u05d5\u05db\u05df \u05de\u05db\u05d9\u05e8\u05d5\u05ea/\u05e4\u05e7\u05d9\u05d3)"
    },
    "parent_agent_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05e1\u05d5\u05db\u05df \u05d0\u05d1"
    },
    "department_id": {
      "type": "number",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05de\u05d7\u05dc\u05e7\u05d4"
    },
    "agency": {
      "type": "string",
      "description": "\u05e1\u05d5\u05db\u05e0\u05d5\u05ea"
    },
    "passport": {
      "type": "string",
      "description": "\u05ea.\u05d6./\u05d7.\u05e4."
    },
    "phone": {
      "type": "string",
      "description": "\u05d8\u05dc\u05e4\u05d5\u05df \u05e8\u05d0\u05e9\u05d9"
    },
    "phone_2": {
      "type": "string",
      "description": "\u05d8\u05dc\u05e4\u05d5\u05df \u05de\u05e9\u05e0\u05d9"
    },
    "fax": {
      "type": "string",
      "description": "\u05e4\u05e7\u05e1"
    },
    "email": {
      "type": "string",
      "description": "\u05d0\u05d9\u05de\u05d9\u05d9\u05dc \u05e8\u05d0\u05e9\u05d9"
    },
    "email_2": {
      "type": "string",
      "description": "\u05d0\u05d9\u05de\u05d9\u05d9\u05dc \u05de\u05e9\u05e0\u05d9"
    },
    "address": {
      "type": "string",
      "description": "\u05db\u05ea\u05d5\u05d1\u05ea"
    },
    "city": {
      "type": "string",
      "description": "\u05e2\u05d9\u05e8"
    },
    "agent_percentage": {
      "type": "number",
      "description": "\u05d0\u05d7\u05d5\u05d6/\u05e1\u05db\u05d5\u05dd \u05e2\u05de\u05dc\u05d4"
    },
    "agent_percentage_type": {
      "type": "string",
      "enum": [
        "percent",
        "nis"
      ],
      "description": "\u05e1\u05d5\u05d2 \u05e2\u05de\u05dc\u05d4 (%/\u20aa)"
    },
    "obligo": {
      "type": "number",
      "description": "\u05d0\u05d5\u05d1\u05dc\u05d9\u05d2\u05d5"
    },
    "road_services": {
      "type": "string",
      "description": "\u05e9\u05d9\u05e8\u05d5\u05ea\u05d9 \u05d3\u05e8\u05da"
    },
    "insurance_companies": {
      "type": "string",
      "description": "\u05d7\u05d1\u05e8\u05d5\u05ea \u05d1\u05d9\u05d8\u05d5\u05d7"
    },
    "branch_id": {
      "type": "number",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05e1\u05e0\u05d9\u05e3"
    },
    "recruit_date": {
      "type": "string",
      "format": "date",
      "description": "\u05ea\u05d0\u05e8\u05d9\u05da \u05d2\u05d9\u05d5\u05e1"
    },
    "start_activity_date": {
      "type": "string",
      "format": "date",
      "description": "\u05ea\u05d7\u05d9\u05dc\u05ea \u05e4\u05e2\u05d9\u05dc\u05d5\u05ea"
    },
    "notes": {
      "type": "string",
      "description": "\u05d4\u05e2\u05e8\u05d5\u05ea"
    },
    "is_insurance_firm": {
      "type": "boolean",
      "description": "\u05d4\u05d0\u05dd \u05d7\u05d1\u05e8\u05ea \u05d1\u05d9\u05d8\u05d5\u05d7"
    },
    "tran_type": {
      "type": "string",
      "enum": [
        "bank",
        "check"
      ],
      "description": "\u05e1\u05d5\u05d2 \u05d4\u05e2\u05d1\u05e8\u05d4 (\u05d1\u05e0\u05e7/\u05e9\u05d9\u05e7)"
    },
    "payment_day": {
      "type": "number",
      "description": "\u05d9\u05d5\u05dd \u05ea\u05e9\u05dc\u05d5\u05dd"
    },
    "bank_code": {
      "type": "string",
      "description": "\u05e7\u05d5\u05d3 \u05d1\u05e0\u05e7"
    },
    "bank_branch": {
      "type": "string",
      "description": "\u05e1\u05e0\u05d9\u05e3 \u05d1\u05e0\u05e7"
    },
    "account_num": {
      "type": "string",
      "description": "\u05de\u05e1\u05e4\u05e8 \u05d7\u05e9\u05d1\u05d5\u05df"
    },
    "tax_rate": {
      "type": "number",
      "description": "\u05e9\u05d9\u05e2\u05d5\u05e8 \u05de\u05e1"
    },
    "tax_until_date": {
      "type": "string",
      "format": "date",
      "description": "\u05ea\u05d5\u05e7\u05e3 \u05e4\u05d8\u05d5\u05e8 \u05de\u05e1"
    },
    "contact_person_name": {
      "type": "string",
      "description": "\u05d0\u05d9\u05e9 \u05e7\u05e9\u05e8 - \u05e9\u05dd"
    },
    "contact_person_phone": {
      "type": "string",
      "description": "\u05d0\u05d9\u05e9 \u05e7\u05e9\u05e8 - \u05d8\u05dc\u05e4\u05d5\u05df"
    },
    "contact_person_role": {
      "type": "string",
      "description": "\u05d0\u05d9\u05e9 \u05e7\u05e9\u05e8 - \u05ea\u05e4\u05e7\u05d9\u05d3"
    }
  },
  "required": [
    "full_name"
  ]
}
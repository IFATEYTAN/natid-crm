    "parent_id_1": {
      "type": "number",
      "description": "\u05d7\u05d1\u05d9\u05dc\u05ea \u05d0\u05d1 1 (\u05d0\u05dd \u05de\u05d0\u05d5\u05d7\u05d3\u05ea)"
    },
    "parent_id_2": {
      "type": "number",
      "description": "\u05d7\u05d1\u05d9\u05dc\u05ea \u05d0\u05d1 2 (\u05d0\u05dd \u05de\u05d0\u05d5\u05d7\u05d3\u05ea)"

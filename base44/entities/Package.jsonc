      "type": "number",
      "description": "\u05de\u05d7\u05d9\u05e8 \u05dc\u05e1\u05d5\u05db\u05df"
    },
    "to_client_price": {
      "type": "number",
      "description": "\u05de\u05d7\u05d9\u05e8 \u05dc\u05dc\u05e7\u05d5\u05d7"
    },
    "version": {
      "type": "number",
      "description": "\u05d2\u05e8\u05e1\u05ea \u05d7\u05d1\u05d9\u05dc\u05d4"

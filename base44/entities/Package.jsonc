      "description": "\u05de\u05d6\u05d4\u05d4 \u05e1\u05e0\u05d9\u05e3"
    },
    "car_age_from": {
      "type": "number",
      "description": "\u05d2\u05d9\u05dc \u05e8\u05db\u05d1 \u05de\u05d9\u05e0\u05d9\u05de\u05dc\u05d9"
    },
    "car_age_to": {
      "type": "number",
      "description": "\u05d2\u05d9\u05dc \u05e8\u05db\u05d1 \u05de\u05e7\u05e1\u05d9\u05de\u05dc\u05d9"
    },

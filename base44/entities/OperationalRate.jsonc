      "description": "\u05e9\u05dd \u05ea\u05e2\u05e8\u05d9\u05e3"
    },
    "rate_type": {
      "type": "string",
      "enum": [
        "base",
        "time_surcharge",
        "area_surcharge",
        "toll_road",
        "vehicle_type",
        "service_type"
      ],
      "description": "\u05e1\u05d5\u05d2 \u05ea\u05e2\u05e8\u05d9\u05e3"
    },
    "condition_key": {
      "type": "string",
      "description": "\u05de\u05e4\u05ea\u05d7 \u05ea\u05e0\u05d0\u05d9"
    },
    "condition_label": {
      "type": "string",
      "description": "\u05ea\u05d9\u05d0\u05d5\u05e8 \u05d4\u05ea\u05e0\u05d0\u05d9 \u05d1\u05e2\u05d1\u05e8\u05d9\u05ea"
    },
